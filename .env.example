# Copy this file to .env and adjust values before starting the project.
# All variables with defaults can be left as-is for local development.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=goodjob
POSTGRES_PASSWORD=goodjob
POSTGRES_DB=goodjob
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ─── MQTT (Eclipse Mosquitto) ─────────────────────────────────────────────────
# Leave empty to disable MQTT; real-time shoutouts will still work via Socket.IO.
MQTT_PORT=1883
MQTT_URL=mqtt://mosquitto:1883

# ─── MinIO (S3-compatible object storage for avatars) ─────────────────────────
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Backend ──────────────────────────────────────────────────────────────────
BACKEND_PORT=7770
DATABASE_URL=postgresql://goodjob:goodjob@postgres:5432/goodjob

# Run TypeORM migrations automatically on startup (set true in production)
TYPEORM_MIGRATIONS_RUN=false

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
FRONTEND_PORT=7777
# In Docker dev: backend is accessed by the browser at this URL.
# In production behind nginx reverse proxy: use /api
VITE_API_URL=http://localhost:7770

# ─── Auth & Security ──────────────────────────────────────────────────────────
# Use long random strings in production (min 32 chars)
JWT_SECRET=dev-access-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32-chars
FRONTEND_URL=http://localhost:7777

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Obtain credentials from https://console.cloud.google.com/apis/credentials
# Leave empty to disable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:7770/auth/google/callback

# ─── SMTP (email delivery for OTP) ───────────────────────────────────────────
# Leave empty to print OTPs to the server log instead of sending email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@localhost

# ─── S3 / MinIO (avatar uploads) ─────────────────────────────────────────────
# Docker dev: S3_ENDPOINT points to the minio container (internal).
# S3_PUBLIC_BASE_URL is what the browser uses to load images (external).
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_BASE_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=avatars

# ─── OpenAI (AI features) ────────────────────────────────────────────────────
# Required for: AI monthly summary, semantic kudo search.
# Leave empty to disable AI features gracefully.
OPENAI_API_KEY=

# ─── OTP Master Code (development / testing only) ────────────────────────────
# Any OTP prompt will accept this code regardless of the actual OTP.
# MUST be left empty in production.
OTP_MASTER_CODE=
