# Copy to .env and adjust as needed (optional for defaults in docker-compose)

POSTGRES_USER=goodjob
POSTGRES_PASSWORD=goodjob
POSTGRES_DB=goodjob
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_URL=redis://redis:6379

BACKEND_PORT=7770
DATABASE_URL=postgresql://goodjob:goodjob@postgres:5432/goodjob

FRONTEND_PORT=7777
# Browser calls API on the host machine (not the frontend container hostname)
VITE_API_URL=http://localhost:7770
