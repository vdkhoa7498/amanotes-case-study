# Copy to .env and adjust as needed (optional for defaults in docker-compose)

POSTGRES_USER=goodjob
POSTGRES_PASSWORD=goodjob
POSTGRES_DB=goodjob
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_URL=redis://redis:6379

BACKEND_PORT=7770
DATABASE_URL=postgresql://goodjob:goodjob@postgres:5432/goodjob

FRONTEND_PORT=7777
VITE_API_URL=http://localhost:7770

JWT_SECRET=dev-access-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32-chars
FRONTEND_URL=http://localhost:7777

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:7770/auth/google/callback

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@localhost

TYPEORM_MIGRATIONS_RUN=false

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_BASE_URL=http://localhost:9000
