# Database & Redis (docker-compose: postgres + redis service names)
DATABASE_URL=postgresql://goodjob:goodjob@localhost:5432/goodjob
REDIS_URL=redis://localhost:6379

# MQTT (Eclipse Mosquitto). Docker: mqtt://mosquitto:1883. Để trống = chỉ đẩy thông báo qua Socket.IO nội bộ.
MQTT_URL=mqtt://localhost:1883

PORT=7770
NODE_ENV=development

# JWT — dùng chuỗi dài ngẫu nhiên trong production
JWT_SECRET=dev-access-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32-chars

# CORS — origin của Vite
FRONTEND_URL=http://localhost:7777

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Dev: callback qua Vite proxy (cùng origin + cookie HttpOnly). Production: URL công khai tới /api/auth/google/callback nếu dùng reverse proxy.
GOOGLE_CALLBACK_URL=http://localhost:7777/api/auth/google/callback

# SMTP (để gửi OTP thật; không có thì OTP in ra log server)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@localhost

TYPEORM_MIGRATIONS_RUN=false

# MinIO / S3 (upload avatar). Docker: S3_ENDPOINT=http://minio:9000; máy host chạy API: http://localhost:9000
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_BASE_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=avatars

# OpenAI (leave empty to disable AI summary)
OPENAI_API_KEY=

# Master OTP — bypasses Redis OTP check for any email/flow (dev/testing only, leave empty in production)
OTP_MASTER_CODE=
